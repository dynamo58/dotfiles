{
    // Set the default
    "editor.formatOnSave": true,
    // Enable per-language
    // "[javascript]": {
    // "editor.formatOnSave": true
    // },
    "editor.selectionClipboard": false, // disable pasting with middle mouse button
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.detectIndentation": true,
    "editor.fontFamily": "'Iosevka', 'Hasklug Nerd Font', 'Iosevka'",
    "editor.fontWeight": "640",
    "editor.wordWrap": "on",
    "editor.minimap.enabled": false,
    "explorer.confirmDelete": false,
    "editor.suggestSelection": "first",
    "workbench.editor.untitled.hint": "hidden",
    "security.workspace.trust.untrustedFiles": "open",
    "extensions.ignoreRecommendations": true,
    "workbench.startupEditor": "none",
    "security.workspace.trust.startupPrompt": "never",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook",
        "*.pdf": "default",
        "*.docx": "default",
        "*.excalidraw": "editor.excalidraw"
    },
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "editor.cursorBlinking": "solid",
    "editor.cursorStyle": "block",
    "explorer.confirmDragAndDrop": false,
    "git.confirmSync": false,
    "security.workspace.trust.banner": "never",
    "terminal.integrated.fontSize": 15,
    "git.enableSmartCommit": true,
    "rust-analyzer.callInfo.full": false,
    "rust-analyzer.inlayHints.enable": false,
    "editor.guides.bracketPairsHorizontal": false,
    "editor.guides.highlightActiveBracketPair": false,
    "editor.fontLigatures": true,
    "workbench.iconTheme": "simple-icons",
    "security.workspace.trust.enabled": false,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.rulers": [
        80,
        120
    ],
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "deno.codeLens.test": false,
    "deno.enable": true,
    "rust-analyzer.cargo.allFeatures": true,
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            80
        ],
        "editor.selectionHighlight": false,
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": false
    },
    "editor.formatOnPaste": true,
    "editor.bracketPairColorization.enabled": false,
    "workbench.colorTheme": "Hybrid dim",
    "git.autofetch": true,
    "editor.renderWhitespace": "boundary",
    "editor.accessibilitySupport": "off",
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingDelete": "always",
    "window.autoDetectHighContrast": false,
    "window.menuBarVisibility": "hidden",
    "terminal.explorerKind": "external",
    "terminal.external.linuxExec": "alacritty",
    "background.enabled": true,
    "background.loop": false,
    "background.useDefault": false,
    "background.useFront": false,
    "background.style": {
        "content": "''",
        "pointer-events": "none",
        "position": "absolute",
        "z-index": "99999",
        "width": "100%",
        "height": "100%",
        "background-size": "cover",
        "background-repeat": "no-repeat",
        "opacity": 0.07
    },
    "background.customImages": [
        "/hdd/media/pictures/wallpapers/wave.jpg",
        "/hdd/media/pictures/wallpapers/0035.jpg"
    ],
    "search.showLineNumbers": true,
    "window.zoomLevel": -1,
    "debug.showInlineBreakpointCandidates": false,
    "audioCues.lineHasBreakpoint": "off"
}